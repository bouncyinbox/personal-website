---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Role {
  company: string;
  title: string;
  dates: string;
  scope: string;
  bullets: string[];
}

const roles: Role[] = [
  {
    company: 'Nielsen',
    title: 'Senior Engineering Manager',
    dates: 'Jun 2025 – Feb 2026',
    scope: '32-member cross-functional engineering team across South Korea, US, and India (4 cities)',
    bullets: [
      'Took over a team previously led by a Director of Engineering for 7+ years; stabilized through a leadership transition — introduced structured planning, clarified ownership boundaries, and established cross-functional engagement models.',
      'Hired 3 engineers during this period.',
      'Reorganized the team to align with the Digital & AI vertical — mapped 6 apps and 4 services, transitioned 3 apps and 5 engineers to appropriate verticals.',
      'Identified a Sev-1 data quality issue on the iOS metering app undetected for 15 months — impacting 2 out of 20 core signals (UserAgent and Classification data) across nearly 100% of global clients. Drove root cause analysis and coordinated the fix across multiple teams.',
      'Drove adoption of AI-assisted developer tooling across teams, personally shipped an enhancement in crawler using LLM integrated runtime loops (a self-healing crawler).',
    ],
  },
  {
    company: 'Myntra',
    title: 'Senior Engineering Manager',
    dates: 'Apr 2022 – Jun 2025',
    scope: '18-member full-stack engineering org within the Discovery domain',
    bullets: [
      'Owned high-traffic customer-facing surfaces: PDP, Size&Fit, UGC, Growth (3D, Virtual TryOn, FWD, Hyperlocal, AI Looks), Recommendations, Search Experience.',
      'Drove PDP migration to the Layout Engine framework — reduced TTFD by ~50% (5.1s → 2.5s), significantly improving scalability and release velocity for one of Myntra\'s highest-traffic pages.',
      'Scaled and optimized backend services handling 2M+ TPS, achieved ~30% infrastructure cost savings through systematic benchmarking, right-sizing, and autoscaling strategies.',
      'Established robust performance and reliability practices (Firebase metrics, profiling, on-call rotations, RCA culture), resulting in ~70% reduction in production incidents.',
      'Partnered cross-functionally with Product, UX, TPM, and Platform teams to deliver complex, high-impact features on time.',
    ],
  },
  {
    company: 'Snapdeal',
    title: 'Engineering Manager (SE II → SSE → Tech Lead → EM)',
    dates: 'Aug 2014 – Mar 2022',
    scope: 'Buyer Experience engineering across Discovery, Post-Order, and Payments domains',
    bullets: [
      'During Snapdeal 2.0 restructuring (80% org-wide workforce reduction), stepped up as one of few senior engineers retained; rebuilt the buyer engineering team from scratch, maintained delivery continuity, and progressed from Senior Engineer to Engineering Manager.',
      'Owned end-to-end Buyer Experience engineering — led development of Cart, Checkout, Payments, PWA, and real-time monitoring systems.',
      'Drove frontend modernization initiatives, improving performance, reliability, and developer productivity across web platforms.',
    ],
  },
  {
    company: 'RedBus / Adjetter',
    title: 'Software Engineer',
    dates: 'Sep 2012 – Jul 2014',
    scope: 'Consumer-facing web and mobile web applications',
    bullets: [
      'Built consumer-facing web and mobile web applications including search result pages, payment flows, and hotel booking platforms from the ground up.',
      'Developed reusable UI libraries in JavaScript; led end-to-end development of an e-commerce platform and a CMS web app.',
      'Built and launched the Hotels vertical for RedBus, expanding the platform\'s service offerings.',
    ],
  },
];
---

<BaseLayout
  title="Experience"
  description="Roles, scope, and outcomes."
>
  <h1>Experience</h1>
  <p class="lede">Reverse-chronological. 13+ years across e-commerce, payments, travel, and marketplace platforms.</p>

  <ul class="entries">
    {roles.map((role) => (
      <li class="entry">
        <div class="entry-head">
          <h3>{role.title} · {role.company}</h3>
          <span class="dates">{role.dates}</span>
        </div>
        <p class="scope">{role.scope}</p>
        <ul>
          {role.bullets.map((b) => <li>{b}</li>)}
        </ul>
      </li>
    ))}
  </ul>
</BaseLayout>
