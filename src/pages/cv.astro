---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

interface Bullet {
  text: string;
  sub?: string[];
}

interface Role {
  company: string;
  title: string;
  dates: string;
  location: string;
  bullets: (string | Bullet)[];
}

const roles: Role[] = [
  {
    company: 'Nielsen',
    title: 'Senior Engineering Manager',
    dates: 'Jun 2025 – Feb 2026',
    location: 'Bangalore, India',
    bullets: [
      'Took over a 32-member cross-functional engineering team (web, backend, Android/iOS) across South Korea, the US, and India (4 cities), previously led by a Director for 7+ years, owning the digital audience measurement portfolio. Stabilized the team through a leadership transition.',
      'Owned consumer digital meters live across 9 countries, capturing browsing, streaming, and e-commerce signals via the Android Accessibility API and VPN-based traffic capture, with on-device data SDKs and WebView-based onboarding/rewards flows backed by user management and incentives services.',
      'Operated as a manager of managers across a multi-geo organization; had 2 EMs and 4 tech leads reporting, conducted skip-level 1:1s, and coached managers on delivery, stakeholder management, and people development.',
      'Identified a Sev-1 data quality issue undetected for 15 months, impacting two core signals across nearly 100% of global clients. Drove root cause analysis and coordinated the fix across multiple teams.',
      'Drove adoption of AI-assisted developer tooling across teams; personally helped ship an enhancement in the crawler using LLM-integrated runtime loops (a self-healing crawler).',
    ],
  },
  {
    company: 'Myntra',
    title: 'Senior Engineering Manager',
    dates: 'Apr 2022 – Jun 2025',
    location: 'Bangalore, India',
    bullets: [
      'Led a team of 18 primarily full-stack developers within storefront engineering, owning high-traffic customer-facing surfaces: PDP, Size & Fit, UGC, Growth (3D, Virtual Try-On, FWD, Hyperlocal, AI Looks), Recommendations, and Search Experience.',
      'Owned the PDP product charter (~50% of Myntra traffic lands on PDP); collaborated with 8–9 product leaders and multiple engineering teams to balance cross-sell, feature education, and core conversion.',
      'Led the architecture and design of the Tag service for social-proof nudges (city-first buyer, units sold, low-stock urgency) across PDP and key funnel touchpoints - lifted PDP-to-Cart by 4%.',
      'Drove PDP migration to the Layout Engine framework — reduced TTFD by ~50% (5.1s → 2.5s), significantly improving scalability and release velocity.',
      'Led development of a new component library MDL 2.0 in collaboration with design - introduced theming support enabling multiple design identities on a shared component foundation, which powered app-in-app experiences for Myntra, FWD, Hyperlocal & Luxe stores within the Myntra app.',
      'Owned the Style microservice powering PDP - 60+ internal clients, 8-10 upstream dependencies, business-critical path where downtime would reduce orders to zero; drove reliability, scalability, and stakeholder coordination across consumers.',
      'Stabilized Style service (P0, business-critical) - introduced service-specific dashboards, granular alerts, VLT-based capacity planning, HPA for cost-aware scaling, and simplified architecture by removing an inconsistent cache pipeline; eliminated recurring P0 escalations during peak periods and deployments.',
      'Established robust performance and reliability practices (Firebase metrics, profiling, on-call rotations, RCA culture), resulting in ~70% reduction in production incidents.',
    ],
  },
  {
    company: 'Snapdeal',
    title: 'Engineering Manager',
    dates: 'Aug 2014 – Mar 2022',
    location: 'Gurugram, India',
    bullets: [
      'Progressed from Senior Engineer II to Senior Software Engineer to Tech Lead to Engineering Manager over 7+ years.',
      'Retained through Snapdeal 2.0 restructuring (80% workforce reduction); rebuilt the buyer web/mobile engineering team from 2 to 14 and sustained product delivery through the transition.',
      'Built and led the BFF (Backend-for-Frontend) layer for dynamic, personalized layouts in collaboration with cross-functional engineering teams - unlocked rapid A/B testing and personalization for product and business teams without frontend release cycles.',
      'Early adopter of AMP, Service Workers (web push), and One Tap Sign-in in collaboration with Google - AMP cut PLP load time by ~50% and lifted mobile web conversion by ~10%, web push drove ~15% re-engagement uplift, and One Tap reduced sign-in friction with ~20% higher sign-in conversion.',
      'Owned web & mobile platform observability and performance - Built in-house RUM and JS error and network logging libraries with dashboards and alerts; moved team from synthetic to real-user monitoring, established perf culture, drove significant page load improvements, cut customer escalations, and surfaced browser-specific conversion issues.',
      'Influenced architecture and engineering standards across web teams; mentored engineers into senior and tech lead roles, several now lead teams at top product companies.',
      /*'Led the team to own complete buyer experience engineering across Discovery, Post-Order, and Payments; built hybrid apps and mobile web for post-order and payment flows - improved funnel conversion, reduced payment failures, and unified the buyer journey across surfaces.',*/
    ],
  },
  {
    company: 'RedBus / Adjetter',
    title: 'Software Engineer',
    dates: 'Sep 2012 – Jul 2014',
    location: 'Bangalore, India',
    bullets: [
      'Built and owned a customer support web app replacing email/phone workflows for cancellation, refund, and post-order queries - cut AHT by ~50%, brought refund TAT from multi-day to same-day, and deflected enough operational load from engineering to redeploy engineers from support to product development.',
      'Built reusable component libraries and led revamp for web and mobile web - improved page load ~30-40% and enabled white-label apps for travel partners.',
      'Built hotel booking flows (details + customer info) on the bus platform post-Ibibo acquisition, enabling hotel cross-sell to bus customers and expanded RedBus into multi-category travel.',
    ],
  },
];

interface SkillGroup {
  category: string;
  items: string;
}

const skills: SkillGroup[] = [
  {
    category: 'Web and Mobile',
    items: 'JavaScript, TypeScript, React, React Native, PWA, Hybrid Mobile Apps, WebView, Rendering Strategies, Web Performance, Frontend Architecture, Android/iOS, Component Libraries',
  },
  {
    category: 'Backend',
    items: 'Golang, Node.js, Microservices, BFF & aggregator patterns, API Gateway, REST, gRPC, GraphQL, CDN, Caching Strategy, High-Scale Platforms, Service Reliability Patterns, AWS, NoSQL (MongoDB, Redis, Aerospike)',
  },
  {
    category: 'Observability & Reliability',
    items: 'Grafana, Prometheus, Firebase, Sentry, SLOs / SLAs, Incident Management, On-call practices, RCAs & Postmortems, Alerting & Monitoring, Circuit Breakers, Rate Limiting',
  },
  {
    category: 'AI & Emerging',
    items: 'Generative AI, AI-Assisted Developer Tooling',
  },
  {
    category: 'Domain Expertise',
    items: 'E-commerce, Travel, Marketplace, Analytics, Market Research, Consumer Internet Products, B2C',
  },
  {
    category: 'Engineering Leadership',
    items: 'Engineering Strategy, Technical Roadmap Planning, Org Design, Hiring & Talent Management, Performance Management, OKR Planning, Headcount Planning, Career Development & Mentorship, Stakeholder Management, Cross-Functional Alignment, Agile / Scrum, Program Delivery, People Management, 1:1 Coaching',
  },
];
---

<BaseLayout
  title="CV"
  description={`CV of ${SITE.author} — Senior Engineering Manager based in ${SITE.city}, ${SITE.country}, with 13+ years across Nielsen, Myntra, Snapdeal, and RedBus. Engineering leadership, distributed systems, and platform reliability.`}
  bodyClass="cv-body"
>
  <div class="cv">
    <div class="cv-actions">
      <button type="button" id="print-cv">Print / Save as PDF</button>
    </div>

    <h1>Amit Kumar</h1>
    <p class="contact-line">
      Senior Engineering Manager | Bangalore, India
      <br />
      +91-8826047975 | bouncyinbox@gmail.com |
      <a href={SITE.linkedin}>{SITE.linkedin.replace('https://www.', '')}</a> |
      <a href={SITE.github}>{SITE.github.replace('https://', '')}</a>
    </p>

    <section>
      <h2>Summary</h2>
      <p>
        Senior Engineering Manager with 13+ years of experience building and scaling consumer internet platforms across e-commerce, travel, and marketplaces. Owned high-traffic web and mobile surfaces (storefront at Myntra, buyer experience at Snapdeal) with measurable impact on conversion, performance, and reliability. Hands-on expertise in frontend architecture, mobile web, hybrid apps, and BFF patterns, backed by full-stack and microservices ownership. Led teams through restructurings, leadership transitions, and multi-geo coordination, with recent work in AI-assisted developer tooling.
      </p>
    </section>

    <section>
      <h2>Experience</h2>
      {roles.map((role) => (
        <div class="role">
          <h3>{role.company} | {role.title}</h3>
          <p class="meta">{role.dates} | {role.location}</p>
          <ul>
            {role.bullets.map((b) => (
              typeof b === 'string'
                ? <li>{b}</li>
                : <li>{b.text}{b.sub && <ul>{b.sub.map((s) => <li>{s}</li>)}</ul>}</li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <section>
      <h2>Skills</h2>
      {skills.map((group) => (
        <p class="skill-group">
          <strong>{group.category}:</strong> {group.items}
        </p>
      ))}
    </section>

    <section>
      <h2>Education</h2>
      <div class="role">
        <h3>Poornima College of Engineering | Bachelor of Technology, Information Technology</h3>
        <p class="meta">Aug 2008 – Jun 2012 | Jaipur, India</p>
        <p class="affiliation">Affiliated with Rajasthan Technical University</p>
      </div>
    </section>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    var btn = document.getElementById('print-cv');
    if (!btn) return;
    btn.addEventListener('click', function () {
      window.print();
    });
  })();
</script>