---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';
---

<BaseLayout
  title={undefined}
  description={`Personal site of ${SITE.author}, Senior Engineering Manager.`}
>
  <div class="hero">
    <img src="/profile.jpeg" alt="Amit Kumar" class="profile-photo" />
    <div>
      <h1>Amit Kumar</h1>
      <p class="lede">
        Senior Engineering Manager · 13+ years building software and the teams that ship it.
      </p>
      <ul class="social-links">
        <li>
          <a href={SITE.linkedin} aria-label="LinkedIn" rel="me noopener" target="_blank">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href={SITE.github} aria-label="GitHub" rel="me noopener" target="_blank">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.58.23 2.75.12 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.26 5.68.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.55C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href={`mailto:${SITE.emailUser}@${SITE.emailDomain}`} aria-label="Email">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="m3 7 9 6 9-6"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <p>
    I build and scale engineering organizations across web, mobile, and backend platforms.
    Hands-on technical depth in frontend, mobile platforms, and high-scale microservices,
    with a consistent focus on platform reliability, developer productivity, and delivery
    execution at scale. I've worked across e-commerce, payments, travel, and marketplace
    platforms at companies like Nielsen, Myntra, Snapdeal, and RedBus.
  </p>

  <p>
    As a manager, I optimize for team autonomy, delivery predictability, and engineering
    excellence. I believe in structured planning, clear ownership boundaries, and building
    a strong culture of performance, reliability, and cross-functional collaboration.
  </p>

  <h2>Elsewhere on this site</h2>
  <ul>
    <li><a href="/experience">Experience</a> — roles, scope, and outcomes.</li>
    <li><a href="/projects">Projects</a> — selected case studies.</li>
    <li><a href="/blog">Blog</a> — thoughts on engineering, leadership, and building at scale.</li>
    <li><a href="/uses">Uses</a> — tools and setup.</li>
    <li><a href="/cv">CV</a> — printable one-pager.</li>
  </ul>
</BaseLayout>
