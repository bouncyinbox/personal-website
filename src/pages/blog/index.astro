---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../config';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const readingTime = (body: string) => {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 220));
};

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${SITE.title} — Blog`,
  description:
    'Essays on engineering leadership, distributed systems, code review, and shipping software with AI-assisted tooling.',
  url: new URL('/blog', SITE.url).href,
  author: { '@type': 'Person', name: SITE.author, url: SITE.url },
  inLanguage: 'en',
  blogPost: posts.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.data.title,
    description: post.data.description,
    url: new URL(`/blog/${post.slug}`, SITE.url).href,
    datePublished: post.data.pubDate.toISOString(),
    ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
    author: { '@type': 'Person', name: SITE.author, url: SITE.url },
  })),
};
---

<BaseLayout
  title="Blog"
  description="Essays by Amit Kumar on engineering leadership, distributed systems, code review, and shipping software with AI-assisted tooling."
  jsonLd={[blogLd]}
>
  <h1>Blog</h1>
  <p class="lede">Essays on engineering leadership, distributed systems, code review, and AI-assisted development — written from 13+ years of building teams and platforms at scale.</p>

  {posts.length === 0 ? (
    <p class="muted">No posts yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`}>{post.data.title}</a>
          <span class="meta">
            {fmt(post.data.pubDate)} · {readingTime(post.body)} min read
          </span>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
