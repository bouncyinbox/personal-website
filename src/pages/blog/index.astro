---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../config';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const readingTime = (body: string) => {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.round(words / 220));
};

const blogLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: `${SITE.title} — Writing`,
  description:
    'Notes on engineering leadership, distributed systems, code review, and AI-assisted development — drawn from years of building teams and platforms at scale.',
  url: new URL('/blog', SITE.url).href,
  author: { '@type': 'Person', name: SITE.author, url: SITE.url },
  inLanguage: 'en',
};
---

<BaseLayout
  title="Writing"
  description="Notes by Amit Kumar on engineering leadership, distributed systems, code review, and AI-assisted development — drawn from years of building teams and platforms at scale."
  jsonLd={[blogLd]}
>
  <h1>Writing</h1>
  <p class="lede">Notes on engineering leadership, distributed systems, code review, and AI-assisted development — drawn from years of building teams and platforms at scale.</p>

  {posts.length === 0 ? (
    <p class="muted">No posts yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`}>{post.data.title}</a>
          <span class="meta">
            {fmt(post.data.pubDate)} · {readingTime(post.body)} min read
          </span>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
