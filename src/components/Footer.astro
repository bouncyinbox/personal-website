---
import { SITE } from '../config';

const year = new Date().getFullYear();
// Lightly obfuscated email — split across data attrs and assembled at click time.
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <p>&copy; {year} {SITE.author}</p>
    <ul>
      <li>
        <a
          id="email-link"
          href="#"
          data-user={SITE.emailUser}
          data-domain={SITE.emailDomain}
        >Email</a>
      </li>
      <li><a href={SITE.linkedin} rel="me">LinkedIn</a></li>
      <li><a href={SITE.github} rel="me">GitHub</a></li>
      <li><a href="https://x.com/amit_k0mar" rel="me">Twitter/X</a></li>
      <li><a href="https://medium.com/@humptytech" rel="me">Medium</a></li>
    </ul>
  </div>
</footer>

<script is:inline>(function(){var e=document.getElementById('email-link');if(!e)return;e.addEventListener('click',function(ev){ev.preventDefault();location.href='mailto:'+(e.getAttribute('data-user')||'')+'@'+(e.getAttribute('data-domain')||'')})})();</script>
