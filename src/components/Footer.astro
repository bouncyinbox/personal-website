---
import { SITE } from '../config';

const year = new Date().getFullYear();
// Lightly obfuscated email — split across data attrs and assembled at click time.
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <p>&copy; {year} {SITE.author}</p>
    <ul>
      <li>
        <a
          id="email-link"
          href="#"
          data-user={SITE.emailUser}
          data-domain={SITE.emailDomain}
        >Email</a>
      </li>
      <li><a href={SITE.linkedin} rel="me">LinkedIn</a></li>
      <li><a href={SITE.github} rel="me">GitHub</a></li>
      <li><a href={SITE.socialUrl} rel="me">{SITE.socialLabel}</a></li>
    </ul>
  </div>
</footer>

<script is:inline>
  (function () {
    var el = document.getElementById('email-link');
    if (!el) return;
    var user = el.getAttribute('data-user') || '';
    var domain = el.getAttribute('data-domain') || '';
    el.addEventListener('click', function (e) {
      e.preventDefault();
      window.location.href = 'mailto:' + user + '@' + domain;
    });
  })();
</script>
