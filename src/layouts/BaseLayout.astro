---
import '../styles/global.css';
import { PLAUSIBLE_DOMAIN, PLAUSIBLE_ENABLED } from '../config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  updatedTime?: Date;
  articleAuthor?: string;
  articleSection?: string;
  articleTags?: readonly string[] | string[];
  robots?: string;
  jsonLd?: Record<string, unknown>[];
  bodyClass?: string;
}

const {
  title,
  description,
  ogImage,
  type,
  publishedTime,
  updatedTime,
  articleAuthor,
  articleSection,
  articleTags,
  robots,
  jsonLd,
  bodyClass,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>(function(){try{var s=localStorage.getItem('theme'),d=matchMedia('(prefers-color-scheme:dark)').matches;document.documentElement.setAttribute('data-theme',s||(d?'dark':'light'))}catch(e){}})();</script>
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      type={type}
      publishedTime={publishedTime}
      updatedTime={updatedTime}
      articleAuthor={articleAuthor}
      articleSection={articleSection}
      articleTags={articleTags}
      robots={robots}
      jsonLd={jsonLd}
    />
    {PLAUSIBLE_ENABLED && (
      <script
        is:inline
        defer
        data-domain={PLAUSIBLE_DOMAIN}
        src="https://plausible.io/js/script.js"
      />
    )}
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site">
      <Header />
      <main id="main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
